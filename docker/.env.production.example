# ============================================================
# WeCreator 生产环境变量模板
# 复制为 .env.production 并填写实际值
# 用法: docker compose -f docker-compose.prod.yml --env-file .env.production up -d
# ============================================================

# ── MySQL ────────────────────────────────────
MYSQL_ROOT_PASSWORD=<强随机密码>
MYSQL_DATABASE=wecreator
MYSQL_USER=wcadmin
MYSQL_PASSWORD=<强随机密码>
MYSQL_PORT=3306

# ── Redis ────────────────────────────────────
REDIS_PASSWORD=<强随机密码>
REDIS_PORT=6379

# ── MongoDB ──────────────────────────────────
MONGO_USER=wcadmin
MONGO_PASSWORD=<强随机密码>
MONGO_DATABASE=wecreator_msg
MONGO_PORT=27017

# ── JWT 双 Token 机制 ────────────────────────
# 生成: openssl rand -hex 32
JWT_SECRET=<至少32字符随机字符串>
JWT_ACCESS_EXPIRES=2h
JWT_REFRESH_SECRET=<至少32字符随机字符串_与JWT_SECRET不同>
JWT_REFRESH_EXPIRES=7d

# ── AES-256 敏感字段加密 ─────────────────────
# AES_KEY 必须恰好 32 字节; AES_IV 必须恰好 16 字节
# 生成: openssl rand -hex 16
AES_KEY=<恰好32字节的密钥>
AES_IV=<恰好16字节的IV>

# ── 微信小程序 ───────────────────────────────
WECHAT_APPID=<微信小程序AppID>
WECHAT_SECRET=<微信小程序AppSecret>

# ── 阿里云 OSS ───────────────────────────────
OSS_BUCKET=wecreator-prod
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY=<阿里云RAM子账号AccessKey>
OSS_SECRET=<阿里云RAM子账号SecretKey>
